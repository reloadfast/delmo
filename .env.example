# Path inside the container where the SQLite database is stored.
# In Docker this should remain /data (volume-mounted).
# For local development, ./data is the default.
DELMO_DATA_DIR=/data

# Secret key used for internal signing (e.g. future session tokens).
# Auto-generated and persisted on first run if left empty.
# Set explicitly if you need reproducibility across restarts.
DELMO_SECRET_KEY=
